    "report:md": "tsx scripts/report.ts",
    "report:pdf": "tsx scripts/pdf.ts",
    "harness:ai": "tsx scripts/generate-ai-harness.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:watch": "tsc -p tsconfig.json --noEmit --watch"
  },
